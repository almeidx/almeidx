---
import ThemeToggle from "@/components/theme-toggle.astro";

function normalizePath(pathname: string) {
	const path = pathname.replace(/\/+$/, "") || "/";

	if (path === "/index" || path === "/index.html") {
		return "/";
	}

	return path.replace(/\.html$/, "");
}

const pathname = normalizePath(Astro.url.pathname);
const isAboutPage = pathname === "/";
const isProjectsPage = pathname.startsWith("/projects");
---

<header class="flex flex-col gap-1 py-8">
	<header class="flex items-center justify-between py-4">
		<h1 class="font-bold text-4xl">Almeida</h1>

		<ThemeToggle />
	</header>

	<nav class="flex gap-2">
		<a
			class:list={[
				"cursor-pointer hover:text-muted-foreground",
				isAboutPage
					? "text-foreground hover:text-muted-foreground"
					: "text-muted-foreground hover:text-foreground",
			]}
			href="/"
		>
			about
		</a>

		<a
			class:list={[
				"cursor-pointer",
				isProjectsPage
					? "text-foreground hover:text-muted-foreground"
					: "text-muted-foreground hover:text-foreground",
			]}
			href="/projects"
		>
			projects
		</a>
	</nav>
</header>
